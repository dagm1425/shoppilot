# LLM synthesis provider config (Phase B)
LLM_SYNTHESIS_PROVIDER=gemini
LLM_SYNTHESIS_API_KEY=
LLM_SYNTHESIS_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_SYNTHESIS_MODEL=gemini-2.5-flash

# Transitional synthesis alias compatibility (deprecated):
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4.1-mini

# Optional synthesis alias reuse from embedding key/model:
# GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# Embedding config (kept explicit and separate from synthesis)
EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDING_MODEL=gemini-embedding-001

# Optional Gemini alias fallbacks for base/model:
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shoppilot
AI_SEARCH_TOP_K=5
AI_HYBRID_CANDIDATE_LIMIT=200
AI_INDEX_BATCH_SIZE=25
AI_INDEX_VERSION=phase4-v1
CHROMA_PERSIST_DIRECTORY=.chroma
CHROMA_COLLECTION_NAME=shoppilot_products

# LangSmith tracing config
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=shoppilot-ai-local
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Observability controls
NODE_ENV=development
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_SAMPLE_RATE=0
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0

{
  "name": "@shoppilot/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm test:unit && pnpm test:int && pnpm test:e2e",
    "test:unit": "jest --config jest.config.ts --selectProjects unit",
    "test:int": "jest --config jest.config.ts --selectProjects integration",
    "test:int:db": "SKIP_DB_CONNECT=false jest --config jest.config.ts --selectProjects integration",
    "test:e2e": "jest --config jest.config.ts --selectProjects e2e"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.3",
    "rxjs": "^7.8.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.4",
    "tsx": "^4.20.5"
  }
}

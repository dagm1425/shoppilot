{
  "name": "@shoppilot/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./catalog-contract": {
      "types": "./dist/catalog-contract.d.ts",
      "default": "./dist/catalog-contract.js"
    },
    "./cart-contract": {
      "types": "./dist/cart-contract.d.ts",
      "default": "./dist/cart-contract.js"
    },
    "./wishlist-contract": {
      "types": "./dist/wishlist-contract.d.ts",
      "default": "./dist/wishlist-contract.js"
    },
    "./address-contract": {
      "types": "./dist/address-contract.d.ts",
      "default": "./dist/address-contract.js"
    },
    "./checkout-contract": {
      "types": "./dist/checkout-contract.d.ts",
      "default": "./dist/checkout-contract.js"
    }
  },
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm test:unit && pnpm test:int && pnpm test:e2e",
    "test:unit": "echo 'No unit tests in @shoppilot/db for Phase 0'",
    "test:int": "echo 'No integration tests in @shoppilot/db for Phase 0'",
    "test:e2e": "echo 'No e2e tests in @shoppilot/db for Phase 0'",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "pnpm prisma:generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "tsx": "^4.20.5"
  }
}
